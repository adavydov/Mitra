{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mitra.local/schemas/risk.schema.json",
  "type": "object",
  "required": [
    "risk_scale",
    "categories",
    "anomaly_triggers"
  ],
  "properties": {
    "risk_scale": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "categories": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      }
    },
    "anomaly_triggers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "id": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
