{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mitra.local/schemas/budget.schema.json",
  "type": "object",
  "required": [
    "id",
    "currency",
    "window",
    "soft_limit",
    "hard_limit",
    "tool_costs"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "currency": {
      "type": "string",
      "default": "tokens"
    },
    "window": {
      "type": "string",
      "default": "daily"
    },
    "soft_limit": {
      "type": "number",
      "minimum": 0
    },
    "hard_limit": {
      "type": "number",
      "minimum": 0
    },
    "tool_costs": {
      "type": "object",
      "additionalProperties": {
        "type": "number",
        "minimum": 0
      }
    }
  },
  "additionalProperties": false
}
