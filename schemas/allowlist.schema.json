  "required": [
    "id",
    "hosts",
    "tools"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "hosts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
