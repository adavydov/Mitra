{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mitra.local/schemas/autonomy.schema.json",
  "type": "object",
  "required": [
    "id",
    "default_level",
    "levels"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "default_level": {
      "type": "string",
      "enum": [
        "AL0",
        "AL1",
        "AL2",
        "AL3"
      ],
      "default": "AL1"
    },
    "levels": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "description",
          "max_risk",
          "max_budget_per_action",
          "allowed_tools"
        ],
        "properties": {
          "description": {
            "type": "string"
          },
          "max_risk": {
            "type": "string",
            "enum": [
              "R0",
              "R1",
              "R2",
              "R3",
              "R4"
            ]
          },
          "max_budget_per_action": {
            "type": "number",
            "minimum": 0
          },
          "allowed_tools": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
